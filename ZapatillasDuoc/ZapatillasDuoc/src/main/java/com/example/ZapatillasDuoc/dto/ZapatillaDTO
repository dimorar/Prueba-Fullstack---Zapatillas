package com.example.zapatillasduoc.dto;

import jakarta.validation.constraints.*;
import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

import java.util.List;

@Data
@AllArgsConstructor
@NoArgsConstructor
public class ZapatillaDTO {
    
    @NotBlank(message = "El modelo no puede estar vacio")
    @Size(min = 2, max = 100, message = "El modelo debe tener entre 2 y 100 caracteres")
    private String modelo;

    @NotBlank(message = "El codigo no puede estar vacio")
    @Size(min = 2, max = 50, message = "El codigo debe tener entre 2 y 50 caracteres")
    private String codigo;
    
    @NotBlank(message = "El genero es obligatorio")
    @Pattern(regexp = "HOMBRE|MUJER|UNISEX", message = "El genero debe ser HOMBRE, MUJER o UNISEX")
    private String genero;
    
    @NotNull(message = "El precio es obligatorio")
    @Min(value = 1, message = "El precio debe ser mayor a 0")
    @Max(value = 99999999, message = "El precio excede el maximo permitido")
    private Integer precio;

    @NotBlank(message = "La descripcion no puede estar vacia")
    @Size(min = 5, max = 255, message = "La descripcion debe tener entre 5 y 255 caracteres")
    private String descripcion;
    
    @NotNull(message = "El stock es obligatorio")
    @Min(value = 0, message = "El stock no puede ser negativo")
    private Integer stock;
    
    @NotNull(message = "Debes ingresar al menos una talla")
    @Size(min = 1, message = "Debes ingresar al menos una talla")
    private List<Double> tallas;

}

